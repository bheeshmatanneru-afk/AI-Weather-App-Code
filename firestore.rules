rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User Profile entity
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('createdAt' in data) || data.createdAt == request.time);
    }

    // Validation for Favorite Coordinates entity
    function isValidFavorite(data, userId) {
      return data.id is int
        && data.name is string && data.name.size() <= 128
        && (data.latitude is float || data.latitude is int)
        && (data.longitude is float || data.longitude is int)
        && (!('country' in data) || (data.country is string && data.country.size() <= 128))
        && (!('admin1' in data) || (data.admin1 is string && data.admin1.size() <= 128))
        && (!('country_code' in data) || (data.country_code is string && data.country_code.size() <= 10))
        && data.userId is string && data.userId == userId && data.userId == request.auth.uid
        && (!('createdAt' in data) || data.createdAt == request.time);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
      allow delete: if false;

      match /favorites/{cityId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFavorite(incoming(), userId);
        allow update: if isOwner(userId) && isValidFavorite(incoming(), userId)
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'latitude', 'longitude', 'country', 'admin1', 'country_code']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
